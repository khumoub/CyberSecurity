# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ── Authentication ─────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_secure_64_char_random_string_here

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── External APIs ──────────────────────────────────────────────────────────────
# NVD API key — get free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Claude API — get at https://console.anthropic.com
CLAUDE_API_KEY=

# ── Stripe Billing ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=security@yourdomain.com
